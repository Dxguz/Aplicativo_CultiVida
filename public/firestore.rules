}  }    }      allow read, write: if false;    match /{document=**} {    // --- REGLAS POR DEFECTO (DENEGAR TODO) ---    }      allow write: if request.auth != null && request.auth.uid == userId;      allow read: if request.auth != null;    match /users/{userId} {    // --- REGLAS PARA USUARIOS ---    }      );        || isAdmin()        (isAgriculturOrProfessional() && resource.data.authorId == request.auth.uid)       allow delete: if request.auth != null && (      // Solo el dueño o admin puede eliminar      );        || isAdmin()        ))          )            )              request.resource.data.likesCount == resource.data.likesCount - 1)              !request.resource.data.likes.hasAny([request.auth.uid]) &&              (resource.data.likes.hasAny([request.auth.uid]) &&              ||              request.resource.data.likesCount == resource.data.likesCount + 1)              request.resource.data.likes.hasAny([request.auth.uid]) &&              (!resource.data.likes.hasAny([request.auth.uid]) &&            (            .hasOnly(['likes', 'likesCount']) &&            request.resource.data.diff(resource.data).affectedKeys()          || (          && resource.data.authorId != request.auth.uid)          .hasOnly(['reports'])          || (request.resource.data.diff(resource.data).affectedKeys()          && resource.data.authorId == request.auth.uid)          .hasOnly(['text', 'originalText'])          (request.resource.data.diff(resource.data).affectedKeys()        (isAgriculturOrProfessional() && (      allow update: if request.auth != null && (      // Pueden editar sus propios posts o reportar                    && request.resource.data.authorId == request.auth.uid;                    && isAgriculturOrProfessional()      allow create: if request.auth != null       // Solo agricultores y profesionales pueden crear      allow read: if request.auth != null && isAgriculturOrProfessional();      // Solo agricultores y profesionales pueden leer          match /ComunidadAgricultoresAgronomos/{postId} {    // --- REGLAS PARA LA COMUNIDAD DE AGRICULTORES Y AGRONOMOS ---    }      );        || isAdmin()        (isMujerRural() && resource.data.authorId == request.auth.uid)       allow delete: if request.auth != null && (      // Solo el dueño o admin puede eliminar      );        || isAdmin()        ))          )            )              )                request.resource.data.likesCount == resource.data.likesCount - 1                !request.resource.data.likes.hasAny([request.auth.uid]) &&                resource.data.likes.hasAny([request.auth.uid]) &&              (              // ❌ quitar like              ||              )                request.resource.data.likesCount == resource.data.likesCount + 1                request.resource.data.likes.hasAny([request.auth.uid]) &&                !resource.data.likes.hasAny([request.auth.uid]) &&              (              // ❤️ agregar like            (            .hasOnly(['likes', 'likesCount']) &&            request.resource.data.diff(resource.data).affectedKeys()          || (          && resource.data.authorId != request.auth.uid)          .hasOnly(['reports'])          || (request.resource.data.diff(resource.data).affectedKeys()          && resource.data.authorId == request.auth.uid)          .hasOnly(['text', 'originalText'])          (request.resource.data.diff(resource.data).affectedKeys()        (isMujerRural() && (      allow update: if request.auth != null && (      // O admin puede hacer cualquier cosa      // O cualquiera puede reportar (agregar a reports array)      // Mujeres rurales pueden editar sus propios posts                    && request.resource.data.authorId == request.auth.uid;                    && isMujerRural()      allow create: if request.auth != null       // Solo mujeres rurales pueden crear posts      allow read: if request.auth != null && isMujerRural();      // Solo mujeres rurales pueden leer          match /ComunidadMujeres/{postId} {    // --- REGLAS PARA LA COMUNIDAD DE MUJERES (SOLO MUJERES RURALES) ---    }      return role == 'agricultor' || role == 'profesional';      let role = get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;    function isAgriculturOrProfessional() {    // Función para verificar si es agricultor o profesional    }      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'mujer_rural';    function isMujerRural() {    // Función para verificar si es mujer rural    }             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';      return request.auth.token.admin == true ||     function isAdmin() {    // Función para verificar si el usuario es admin      match /databases/{database}/documents {service cloud.firestore {service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- FUNCIONES HELPER ---
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return request.auth != null && request.auth.uid == uid;
    }

    function isAdmin() {
      return request.auth != null && request.auth.email == 'cultivida.01@gmail.com';
    }

    // --- USUARIOS ---
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isOwner(userId);
      allow update: if isAdmin();
    }

    // --- CURSOS MUJERES ---
    match /cursos_mujeres/{cursoId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAdmin();
    }

    // --- PROGRESO CURSOS ---
    match /usuarios/{userId}/progresCursos/{cursoId} {
      allow read: if isOwner(userId);
      allow write: if isOwner(userId);
    }

    // --- PQRS ---
    match /pqrs/{document=**} {
      allow create: if isAuthenticated();
      allow read, update, delete: if isAdmin();
    }

    // --- CHATS ---
    match /chats/{chatId} {
      allow read: if isAuthenticated() && (request.auth.uid in resource.data.participantes);
      allow create: if isAuthenticated() && request.resource.data.keys().hasAll(['participantes']) && (request.auth.uid in request.resource.data.participantes);
      allow update: if isAuthenticated() && (request.auth.uid in resource.data.participantes);
      allow delete: if isAdmin();
    }

    match /chats/{chatId}/messages/{messageId} {
      allow read: if isAuthenticated() && (request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participantes);
      allow create: if isAuthenticated() && request.resource.data.remitente == request.auth.uid;
      allow update, delete: if isAuthenticated() && resource.data.remitente == request.auth.uid;
    }

    // === COMUNIDADES ===
    
    // COMUNIDAD AGRICULTORES/PROFESIONALES
    match /ComunidadAgricultoresAgronomos/{postId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if request.auth.uid == resource.data.authorId || isAdmin();
    }

    // COMUNIDAD MUJERES RURALES
    match /ComunidadMujeres/{postId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if request.auth.uid == resource.data.authorId || isAdmin();
    }

    // --- USUARIOS BLOQUEADOS ---
    match /blocked_users/{document=**} {
      allow read, write: if isAdmin();
    }

    // --- DENY ALL BY DEFAULT ---
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
