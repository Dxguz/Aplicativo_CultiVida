rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Funciones helper
    function isAdmin() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isOwner(authorId) {
      return request.auth.uid == authorId;
    }

    // ============================================
    // REGLAS PARA LA COMUNIDAD DE MUJERES RURALES
    // ============================================
    match /ComunidadMujeres/{postId} {
      // Leer: cualquier usuario autenticado
      allow read: if request.auth != null;
      
      // Crear: solo el usuario autenticado como autor
      allow create: if request.auth != null && 
                       request.resource.data.authorId == request.auth.uid;
      
      // Actualizar: comentarios, likes, reportes
      allow update: if request.auth != null && (
        // Cualquier usuario autenticado puede actualizar
        // comentarios, likes, reportes
        request.resource.data.diff(resource.data).affectedKeys().hasAny(['comments', 'likes', 'likesCount', 'reports']) ||
        // Solo el autor puede editar el texto
        (isOwner(resource.data.authorId) && 
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['text', 'originalText']))
      ) || isAdmin();
      
      // Eliminar: solo el autor o admin
      allow delete: if request.auth != null && 
                       (isOwner(resource.data.authorId) || isAdmin());
    }

    // ================================================
    // REGLAS PARA LA COMUNIDAD DE AGRICULTORES/AGRONOMOS
    // ================================================
    match /ComunidadAgricultoresAgronomos/{postId} {
      // Leer: cualquier usuario autenticado
      allow read: if request.auth != null;
      
      // Crear: solo el usuario autenticado como autor
      allow create: if request.auth != null && 
                       request.resource.data.authorId == request.auth.uid;
      
      // Actualizar: comentarios, likes, reportes
      allow update: if request.auth != null && (
        // Cualquier usuario autenticado puede actualizar
        // comentarios, likes, reportes
        request.resource.data.diff(resource.data).affectedKeys().hasAny(['comments', 'likes', 'likesCount', 'reports']) ||
        // Solo el autor puede editar el texto
        (isOwner(resource.data.authorId) && 
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['text', 'originalText']))
      ) || isAdmin();
      
      // Eliminar: solo el autor o admin
      allow delete: if request.auth != null && 
                       (isOwner(resource.data.authorId) || isAdmin());
    }

    // ========================================
    // REGLAS PARA PANEL DE CONTROL DEL ADMIN
    // ========================================
    match /blocked_users/{userId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    match /reports/{reportId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    match /notifications/{notificationId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow write: if isAdmin();
    }

    // Colección de usuarios
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth.uid == userId;
      allow update: if isAdmin();
    }

    // ==================
    // REGLAS GENERALES
    // ==================
    match /{document=**} {
      allow read, write: if false;
    }
  }
}





































































































































